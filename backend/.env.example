# MatchDay Command — Backend Environment Variables
# Copy to .env and fill in your values

# Google Cloud Project ID (required for Vertex AI + real Firestore)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Maps Platform API Key (required for real route calculation)
GOOGLE_MAPS_API_KEY=your-maps-api-key

# Gemini API Key
GEMINI_API_KEY=your-gemini-api-key

# Set to true to use real Firestore instead of in-memory mock
USE_REAL_FIRESTORE=false

# Vertex AI region
VERTEX_AI_LOCATION=us-central1

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
