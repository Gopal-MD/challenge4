# ============================================================
#  MatchDay Command — .gitignore
# ============================================================

# ----------------------------
# Python
# ----------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
*.egg-link
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Environment variables / secrets
.env
.env.*
!.env.example
*.env

# pytest
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml

# mypy / type checking
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff / flake8
.ruff_cache/

# ----------------------------
# Node / JavaScript / TypeScript
# ----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-store/

# Build output
dist/
dist-ssr/
*.local

# Vite cache
.vite/
.vite-cache/

# Next.js
.next/
out/

# Nuxt.js
.nuxt/
.output/

# Svelte
.svelte-kit/

# Coverage
coverage/
*.lcov
.nyc_output/

# Vitest
vitest.config.ts.timestamp*

# ----------------------------
# IDE & Editor
# ----------------------------
# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains (IntelliJ, PyCharm, WebStorm, etc.)
.idea/
*.iml
*.ipr
*.iws
out/

# Vim/Neovim
*.swp
*.swo
*.swn
.netrwhist
Session.vim
.vim/

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
auto-save-list

# Sublime Text
*.sublime-workspace
*.sublime-project

# ----------------------------
# Operating System
# ----------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ----------------------------
# Docker
# ----------------------------
.dockerignore
docker-compose.override.yml
*.pid

# ----------------------------
# Google Cloud / GCP
# ----------------------------
# Service account keys — NEVER commit these
*.json
!package.json
!package-lock.json
!tsconfig.json
!tsconfig.node.json
!vitest.config.json
!manifest.json
!firebase.json
service-account*.json
gcp-key*.json
credentials.json
application_default_credentials.json

# gcloud configuration
.gcloud/

# ----------------------------
# Logs
# ----------------------------
logs/
*.log
log/
npm-debug.log
yarn-debug.log
yarn-error.log

# ----------------------------
# Testing & QA
# ----------------------------
playwright-report/
test-results/
e2e-results/
cypress/videos/
cypress/screenshots/

# ----------------------------
# Misc
# ----------------------------
*.bak
*.tmp
*.temp
.cache/
.parcel-cache/
*.map

# Load test artifacts
load_tests/results/
locust-report/
